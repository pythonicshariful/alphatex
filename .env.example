# .env.example
# Copy this file to .env and configure your variables. Do NOT commit the .env file to Git.

SECRET_KEY=your-super-secret-key-change-in-production
DATABASE_URL=sqlite:///shop.db

# SMTP Mail Settings for Email OTP
SMTP_SERVER=alphatex.bd
SMTP_PORT=465
SMTP_USERNAME=no-reply@alphatex.bd
SMTP_PASSWORD=your-email-password

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# reCAPTCHA / Turnstile (Cloudflare Site Key)
RECAPTCHA_SITE_KEY=your-turnstile-site-key
RECAPTCHA_SECRET_KEY=your-turnstile-secret-key

# Admin IP Whitelist (comma-separated, leave blank to disable)
ADMIN_ALLOWED_IPS=127.0.0.1,192.168.1.1
