# .env.example
# Copy this file to .env and configure your variables. Do NOT commit the .env file to Git.

SECRET_KEY=your-super-secret-key-change-in-production

# ── Database (choose ONE option) ──────────────────────────────────────────────
#
# OPTION A — Recommended for Supabase (paste password as-is, no encoding needed)
DB_HOST=db.wupyyvkkzmlmyueczahn.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR-ACTUAL-PASSWORD-HERE
#
# OPTION B — Single URL (only use if password has NO special chars like @ # %)
# DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.wupyyvkkzmlmyueczahn.supabase.co:5432/postgres
#
# LOCAL SQLITE (comment out DB_HOST above and uncomment this for local dev):
# DATABASE_URL=sqlite:///shop.db
# ──────────────────────────────────────────────────────────────────────────────

# SMS / OTP (Twilio - leave blank to use console mock)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-from-number

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# reCAPTCHA / Turnstile (Cloudflare Site Key)
RECAPTCHA_SITE_KEY=your-turnstile-site-key
RECAPTCHA_SECRET_KEY=your-turnstile-secret-key

# Admin IP Whitelist (comma-separated, leave blank to disable)
ADMIN_ALLOWED_IPS=127.0.0.1,192.168.1.1
